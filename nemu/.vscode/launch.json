{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "(gdb) 启动 NEMU",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/riscv32-nemu-interpreter",
            "args": [
                "-f",
                "/data/peterw/Repositories/forgejo.pwdevstudio.internal/ysyx-project/ysyx-project/ysyx-workbench/am-kernels/tests/cpu-tests/build/quick-sort-riscv32e-nemu.elf",
                "/data/peterw/Repositories/forgejo.pwdevstudio.internal/ysyx-project/ysyx-project/ysyx-workbench/am-kernels/tests/cpu-tests/build/quick-sort-riscv32e-nemu.bin"
            ],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "为 gdb 启用整齐打印",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "将反汇编风格设置为 Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "(gdb) 启动 gen-expr",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/tools/gen-expr/build/gen-expr",
            "args": [
                "1000"
            ],
            "stopAtEntry": false,
            "cwd": "${fileDirname}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "为 gdb 启用整齐打印",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "将反汇编风格设置为 Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}